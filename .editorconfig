# =============================================================================
# SECTION 14: TEST PROJECT OVERRIDES
# =============================================================================
[{*Tests/**/*.cs,tests/**/*.cs}]
dotnet_diagnostic.CA1707.severity = none

# TUnit Assert.That reports false positives for MA0042 because the analyzer cannot model the assertion API shape.
dotnet_diagnostic.MA0042.severity = none
