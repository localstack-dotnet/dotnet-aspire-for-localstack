# =============================================================================

# -----------------------------------------------------------------------------
# 10.1 Configuration
# -----------------------------------------------------------------------------
MA0051.maximum_lines_per_method = 80
MA0051.maximum_statements_per_method = 60
MA0011.exclude_tostring_methods = true
# -----------------------------------------------------------------------------
# 10.2 String/Culture Rules
# [OVERLAP GROUP] - Also enforced by CA1304-CA1311
# Keeping both for stricter checking - disable MA if too noisy
# -----------------------------------------------------------------------------
# MA0001 ≈ CA1307, CA1309, CA1310 (StringComparison)
# MA0011 ≈ CA1304, CA1305, CA1311 (IFormatProvider/CultureInfo)
# MA0074 ≈ CA1307, CA1309 (Equals StringComparison)
dotnet_diagnostic.MA0006.severity = suggestion

# -----------------------------------------------------------------------------
# 10.3 Async Rules
# [OVERLAP GROUP] - Also enforced by VSTHRD and CA
# MA0045 overlaps with CA1849/VSTHRD103 - keeping for extra coverage
# -----------------------------------------------------------------------------
